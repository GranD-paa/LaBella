# Copy to project root as `.env.local` for local development.
# In Vercel: Project Settings → Environment Variables → add the same keys.

# ---------------------------------------------------------------------------
# Data source
# ---------------------------------------------------------------------------
# Use `local` for fast offline UI development with in-memory mock data.
# Use `supabase` (or omit this variable) for production / real backend.
NEXT_PUBLIC_DATA_SOURCE=local

# ---------------------------------------------------------------------------
# Supabase (required when NEXT_PUBLIC_DATA_SOURCE=supabase)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
